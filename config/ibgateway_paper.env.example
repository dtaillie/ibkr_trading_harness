# Copy to config/ibgateway_paper.env and chmod 600 before using.
#
# This file is intentionally ignored by git because it may contain paper
# credentials. Prefer paper-only credentials. Do not store live credentials.

# manual = do not start Gateway; assume you start/login yourself.
# direct = launch IB Gateway directly; you type credentials in the GUI.
# ibc    = launch Gateway through IBC; IBC enters username/password, you
#          approve IBKR Mobile 2FA manually.
IBGATEWAY_START_MODE=manual

IBGATEWAY_PATH=/path/to/Jts/ibgateway/VERSION/ibgateway
IBGATEWAY_TRADING_MODE=paper
IBGATEWAY_API_PORT=4002

# Needed by GUI apps launched from systemd user services on most desktops.
DISPLAY=:0

# IBC mode only.
IBC_PATH=/opt/IBC
IBC_INI=/path/to/ibc/paper/config.ini
IBC_GATEWAY_VERSION=1045
IBC_USERNAME=
IBC_PASSWORD=
